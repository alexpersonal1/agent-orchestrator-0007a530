# FitPro Mobile App - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# OLLAMA / CLAUDE CODE CONFIGURATION
# =============================================================================

# Base URL for Ollama API (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic Auth Token for Ollama integration (required: 'ollama')
ANTHROPIC_AUTH_TOKEN=ollama

# Anthropic API Key (leave empty when using Ollama)
ANTHROPIC_API_KEY=

# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================

# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Webhook URL for receiving Telegram updates (use ngrok for local development)
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram

# =============================================================================
# WHATSAPP EVOLUTION API CONFIGURATION
# =============================================================================

# Evolution API base URL (self-hosted instance)
WHATSAPP_API_URL=http://localhost:8080

# Instance name for WhatsApp connection
WHATSAPP_INSTANCE_NAME=fitpro-instance

# API Key for Evolution API authentication
WHATSAPP_API_KEY=your_whatsapp_api_key_here

# =============================================================================
# REDIS CONFIGURATION (Message Bus)
# =============================================================================

# Redis host for message bus
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis password (optional)
REDIS_PASSWORD=

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment: development, staging, production
APP_ENV=development

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Webhook server port
WEBHOOK_PORT=3000

# =============================================================================
# RECOMMENDED MODELS (via Ollama)
# =============================================================================
# • kimi-k2.5:cloud - Best for fitness coaching
# • glm-5:cloud - Excellent for nutrition advice
# • qwen3.5:cloud - Great for automation tasks
# • minimax-m2.7:cloud - Balanced alternative
# =============================================================================
